# Supabase Configuration
# Get these from https://supabase.com/dashboard → Project Settings → API

# Public Supabase URL - safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key - safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key - KEEP SECRET, server-side only
# Used by API routes for privileged database operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# AI Service Configuration
# The app uses OpenRouter for AI itinerary generation

# OpenRouter API Key (Required)
# Get from https://openrouter.ai/keys
# Supports Claude, GPT, Gemini, and other models
OPENROUTER_API_KEY=sk-or-...

# OpenRouter Model (Optional)
# Default: anthropic/claude-3.5-sonnet
# Other options: openai/gpt-4, google/gemini-2.0-flash, meta-llama/llama-3.3-70b, etc.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet


# Optional: Deployment & Analytics
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://vibetrip.com

# Supabase Configuration
# Get these from https://supabase.com/dashboard → Project Settings → API

# Public Supabase URL - safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key - safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key - KEEP SECRET, server-side only
# Used by API routes for privileged database operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# AI Service Configuration
# The app uses OpenRouter for AI itinerary generation

# OpenRouter API Key (Required)
# Get from https://openrouter.ai/keys
# All models below use the :free tier (no cost, 200 req/day limit)
OPENROUTER_API_KEY=sk-or-...

# Hardcoded Models (no need to change)
# The app automatically uses optimal free models for each use case:
# - Web Search/Research: qwen/qwen-3.5-72b-instruct:free (best for research with tools)
# - Itinerary Planning: meta-llama/llama-3.3-70b-instruct:free (best structured output)
# - Chat/Conversation: google/gemma-3-27b-it:free (fast, conversational)
# - Review/Validation: deepseek/deepseek-r1:free (best reasoning)

# OpenRouter Vision Model for Bill Scanning (Optional)
# Default: google/gemini-flash-1.5
# Used by /api/ai/scan-bill to extract expense data from receipt images
OPENROUTER_VISION_MODEL=google/gemini-flash-1.5


# Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Cron job secret — protects /api/polls/check-deadlines
# Set to a random string; pass as X-Cron-Secret header from your scheduler
CRON_SECRET=your-cron-secret

# Optional: Deployment & Analytics
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://vibetrip.com
